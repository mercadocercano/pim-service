# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pim_db
DB_SSLMODE=disable

# Server Configuration
PORT=8080
GIN_MODE=release

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=2112

# Logging
LOG_LEVEL=info

# AI Gateway Configuration
AI_GATEWAY_URL=http://ai-gateway:8000
AI_GATEWAY_API_KEY=your-ai-gateway-api-key-here

# MongoDB Configuration (for Global Catalog)
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=admin123
MONGO_DATABASE=pim_marketplace
